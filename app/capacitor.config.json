{
  "appId": "com.rentverifier.app",
  "appName": "Rent Verifier",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "Camera": {
      "permissions": ["camera", "photos"]
    },
    "Filesystem": {}
  },
  "server": {
    "androidScheme": "https",
    "hostname": "localhost"
  },
  "build": {
    "android": {
      "minSdkVersion": 21,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34
    }
  }
}
